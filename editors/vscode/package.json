  "version": "0.1.0",
  "publisher": "aaronbassett",
  "license": "MIT",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "compact",
    "midnight"
  ],
  "repository": {
    "type": "git",
